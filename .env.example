# Server
PORT=3000

# PostgreSQL (recommended for live site: use DATABASE_URL from your hosted provider)
# DATABASE_URL=postgresql://username:password@host:5432/ella_cloud?sslmode=require

# Optional: force SSL on/off if needed by your provider
# PGSSL=true

# Local PostgreSQL fallback (leave commented out if using DATABASE_URL)
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=ella_cloud
# PGUSER=postgres
# PGPASSWORD=your_password

# Optional SMTP config for notification emails
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@example.com
# SMTP_PASS=your_email_password_or_app_password
# CONTACT_TO=info@ellacloud.co.ke
